{
  "$schema": "https://turbo.build/json-schema.json",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_*",
    "SUPABASE_*",
    "ANTHROPIC_*",
    "RESEND_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "@zyperia/shared-ui#build": {
      "outputs": []
    },
    "@zyperia/shared-lib#build": {
      "outputs": []
    },
    "@zyperia/shared-config#build": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}