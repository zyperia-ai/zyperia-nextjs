# ZYPERIA Project — Environment Variables Template
# Copy this to .env.local and fill in actual values
# DO NOT commit .env.local to Git (it's in .gitignore)

# ============================================================================
# SUPABASE — Database & Authentication
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Used in client-side code (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================================
# CONTENT MACHINE — API Keys for Stage Scripts (Stages 0-6)
# ============================================================================

# Stage 0 (23:00 UTC): Competitive Analysis
# Get from: https://serpapi.com/
SERP_API_KEY=your-serp-api-key-here

# Stage 2 (02:00 UTC): Content Generation
# Option A: Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
NEXT_PUBLIC_ANTHROPIC_MODEL=claude-opus-4-6

# Option B: Phi-4 via Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434

# Option C: Google Gemini
GOOGLE_API_KEY=your-gemini-api-key-here

# Stage 3 (03:00 UTC): Visual Enrichment
# Stable Diffusion via Replicate API
REPLICATE_API_KEY=your-replicate-api-key-here

# Stage 4 (04:00 UTC): Plagiarism Check & Verification
# Copyscape plagiarism detection
COPYSCAPE_API_TOKEN=your-copyscape-token-here

# ============================================================================
# STAGE 6: PUBLISHING — Integration APIs (09:00, 14:00, 18:00 UTC)
# ============================================================================

# Google Search Console — URL indexing
GSC_API_KEY=your-gsc-api-key-here

# Google Analytics 4 — Event tracking
NEXT_PUBLIC_GA4_ID=G_YOUR_GA4_ID
GA4_PROPERTY_ID=G-XXXXXXXXXX
GA4_MEASUREMENT_ID=your-ga4-measurement-id-here

# ============================================================================
# OPTIONAL: External Services
# ============================================================================

# Beehiiv — Newsletter management
BEEHIIV_API_KEY=your-beehiiv-api-key-here
BEEHIIV_PUBLICATION_ID=your-publication-id-here

# Slack — Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url

# Sentry — Error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn-here

# ============================================================================
# APP CONFIGURATION
# ============================================================================

# Environment
NODE_ENV=production
NEXT_PUBLIC_ENVIRONMENT=production

# Blog URLs
NEXT_PUBLIC_CRYPTO_URL=https://crypto.zyperia.ai
NEXT_PUBLIC_INTELLIGENCE_URL=https://intelligence.zyperia.ai
NEXT_PUBLIC_ONLINEBIZ_URL=https://onlinebiz.zyperia.ai

# ============================================================================
# COST BREAKDOWN (Monthly)
# ============================================================================
# SerpAPI:        €5-15    (Stage 0: competitive analysis)
# Replicate:      €10-30   (Stage 3: image generation)
# Copyscape:      €20-50   (Stage 4: plagiarism checks)
# Gemini Flash:   €5-15    (Stage 4: fact-checking)
# Anthropic:      €50-100  (Stage 2: Claude API fallback, if needed)
# Total:          €90-210
#
# Free alternatives:
# - Phi-4 via Ollama (local, zero cost)
# - Google Analytics 4 (free tier)
# - Google Search Console (free)
#
# ============================================================================
