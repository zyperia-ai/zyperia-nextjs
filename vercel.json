{
  "version": 2,
  "projects": [
    {
      "name": "crypto",
      "srcDir": "apps/crypto"
    },
    {
      "name": "intelligence",
      "srcDir": "apps/intelligence"
    },
    {
      "name": "onlinebiz",
      "srcDir": "apps/onlinebiz"
    }
  ],
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "env": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "SUPABASE_URL",
    "SUPABASE_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "ANTHROPIC_API_KEY",
    "SERP_API_KEY",
    "REPLICATE_API_KEY",
    "COPYSCAPE_API_TOKEN",
    "GEMINI_API_KEY",
    "GSC_API_KEY",
    "GA4_PROPERTY_ID",
    "GOOGLE_API_KEY",
    "OLLAMA_BASE_URL"
  ],
  "crons": [
    {
      "path": "/api/cron/stage-0-competitive-analysis",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/stage-1-research-topics",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/stage-2-generate-articles",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/stage-3-visual-enrichment",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/stage-4-plagiarism-check",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/stage-5-editorial-review",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/stage-6-publishing-0900",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/stage-6-publishing-1400",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/stage-6-publishing-1800",
      "schedule": "0 18 * * *"
    }
  ]
}
